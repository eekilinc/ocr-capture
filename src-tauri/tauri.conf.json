{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Metin Yakalayıcı",
  "version": "0.1.0",
  "description": "Ekran görüntülerinden hızlı ve çevrimdışı metin ayıklama aracı.",
  "copyright": "© 2026 Ekrem Kılınç",
  "identifier": "com.ekrem.metin-yakalayici",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Metin Yakalayıcı",
        "width": 1220,
        "height": 820,
        "minWidth": 900,
        "minHeight": 620,
        "resizable": true,
        "maximizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
